<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.QuadCurve?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>


<Pane maxHeight="-Infinity"
    maxWidth="-Infinity"
    minHeight="-Infinity"
    minWidth="-Infinity"
    prefHeight="490.0"
    prefWidth="729.0"
    xmlns="http://javafx.com/javafx/23.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cinema.controllers.ModifierSalleController">
    <children>
        <MenuBar layoutY="1.0" prefHeight="26.0" prefWidth="729.0">
            <menus>
                <Menu fx:id="gestionFranchise" mnemonicParsing="false" text="Gestion franchises">
                    <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                            <image>
                                <Image url="@../images/franchise_32x32.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <items>
                        <MenuItem fx:id="bListeFranchise" mnemonicParsing="false"
                            onAction="#bListFranchiseClick" text="Liste franchises" />
                        <MenuItem fx:id="bAjouterFranchise" mnemonicParsing="false"
                            onAction="#bAjouterFranchiseClick" text="Ajouter une franchise" />
                    </items>
                </Menu>
                <Menu fx:id="gestionCinema" mnemonicParsing="false" text="Gestion cinéma">
                    <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                            <image>
                                <Image url="@../images/cinema_32x32.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <items>
                        <MenuItem fx:id="bListeCinema" mnemonicParsing="false"
                            onAction="#bListeCinemaClick" text="Liste des cinémas" />
                        <MenuItem fx:id="bAjouterCinema" mnemonicParsing="false"
                            onAction="#bAjouterCinemaClick" text="Ajouter un cinéma" />
                    </items>
                </Menu>
                <Menu fx:id="gestionSalle" mnemonicParsing="false" text="Gestion salles">
                    <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                            <image>
                                <Image url="@../images/salle_32x32.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <items>
                        <MenuItem fx:id="bListeSalle" mnemonicParsing="false"
                            onAction="#bListeSalleClick" text="Liste des salles" />
                        <MenuItem fx:id="bAjouterSalle" mnemonicParsing="false"
                            onAction="#bAjouterSalleClick" text="Ajouter une salle" />
                    </items>
                </Menu>
                <Menu fx:id="bAutres" mnemonicParsing="false" text="Autres">
                    <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                            <image>
                                <Image url="@../images/info.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <items>
                        <MenuItem fx:id="bAccueil" mnemonicParsing="false" onAction="#bAccueilClick"
                            text="Accueil" />
                        <MenuItem fx:id="bQuitter" mnemonicParsing="false" onAction="#bQuitterClick"
                            text="Quitter" />
                    </items>
                </Menu>
                <Menu fx:id="bUtilisateur" mnemonicParsing="false" text="Gestion de l'utilisateur">
                            <graphic>
                                <ImageView fitWidth="16" fitHeight="16">
                                    <image>
                                        <Image url="@../images/user.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <items>
                                <MenuItem fx:id="bInfoPerso" mnemonicParsing="false" onAction="#bInfoPerso" text="Modifier informations personnelles" />
                                <MenuItem fx:id="bMdp" mnemonicParsing="false" onAction="#bMdp" text="Modifier mot de passe" />
                            </items>
                        </Menu>
            </menus>
        </MenuBar>


        <Label alignment="CENTER"
            contentDisplay="CENTER"
            layoutY="45.0"
            prefHeight="35.0"
            prefWidth="727.0"
            text="MODIFICATION D'UNE SALLE"
            textAlignment="CENTER"
            textFill="#024010">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>


        <HBox alignment="CENTER_LEFT"
            layoutY="90.0"
            prefHeight="44.0"
            prefWidth="727.0"
            spacing="10.0">
            <children>
                <Label alignment="CENTER"
                    prefHeight="17.0"
                    prefWidth="165.0"
                    text="Numéro de salle : "
                    textFill="#024010">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <Spinner fx:id="spNumero" prefHeight="26.0" prefWidth="375.0" editable="true" />
            </children>
        </HBox>


        <HBox alignment="CENTER_LEFT"
            layoutY="145.0"
            prefHeight="44.0"
            prefWidth="727.0"
            spacing="10.0">
            <children>
                <Label alignment="CENTER"
                    prefHeight="17.0"
                    prefWidth="165.0"
                    text="Description : "
                    textFill="#024010">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="tfDescription" prefHeight="26.0" prefWidth="375.0" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT"
            layoutY="200.0"
            prefHeight="44.0"
            prefWidth="727.0"
            spacing="10.0">
            <children>
                <Label alignment="CENTER"
                    prefHeight="17.0"
                    prefWidth="165.0"
                    text="Nombre de place : "
                    textFill="#024010">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <Spinner fx:id="spNbPlace" prefHeight="26.0" prefWidth="375.0" editable="true" />
            </children>
        </HBox>


        <HBox alignment="CENTER_LEFT"
            layoutY="255.0"
            prefHeight="66.0"
            prefWidth="727.0"
            spacing="10.0">
            <children>
                <Label alignment="CENTER"
                    prefHeight="17.0"
                    prefWidth="165.0"
                    text="Cinéma : "
                    textFill="#024010">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <ListView fx:id="lvCinema" prefHeight="37.0" prefWidth="375.0" />
            </children>
        </HBox>


        <HBox alignment="CENTER"
        layoutY="330.0"
        prefWidth="729.0"
        spacing="5.0">
            <children>
                <Button
                fx:id="bAjtCinema"
                text="Ajouter un cinéma"
                onAction="#bAjtCinemaClick" />
            </children>
        </HBox>
        

        <HBox alignment="CENTER"
        layoutY="365.0"
        prefWidth="729.0"
        spacing="5.0">
            <children>
                <Label fx:id="lbFeedback"
                    text=""/>
            </children>
        </HBox>

        <HBox alignment="CENTER"
            layoutX="-1.0"
            layoutY="395.0"
            prefHeight="100.0"
            prefWidth="729.0"
            spacing="20.0">
            <children>
                <Button fx:id="bEnregistrer"
                    mnemonicParsing="false"
                    onAction="#bEnregistrerClick"
                    prefHeight="39.0"
                    prefWidth="200.0"
                    text="ENREGISTRER"
                    textFill="#024010"
                    defaultButton="true">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>
                <Button fx:id="bRetour"
                    mnemonicParsing="false"
                    onAction="#bRetourClick"
                    prefHeight="39.0"
                    prefWidth="200.0"
                    text="RETOUR"
                    textFill="#024010"
                    cancelButton="true">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>
            </children>
        </HBox>


        <!-- Courbe verte en bas des boutons -->
        <Pane layoutX="0.0" layoutY="460.0" prefHeight="30.0" prefWidth="729.0">
            <children>
                <QuadCurve controlX="7.666656494140625"
                    controlY="-35.99993896484375"
                    endX="409.6666259765625"
                    endY="9.333282470703125"
                    fill="#3A3AB6"
                    layoutX="348.0"
                    layoutY="30.0"
                    startX="-399.66668701171875"
                    startY="9.333282470703125"
                    stroke="BLACK"
                    strokeType="INSIDE"
                    strokeWidth="0.0" />
            </children>
        </Pane>


        <Rectangle arcHeight="5.0"
            arcWidth="5.0"
            fill="#01a321"
            height="5.0"
            layoutX="101.0"
            layoutY="77.0"
            stroke="BLACK"
            strokeType="INSIDE"
            strokeWidth="0.0"
            width="508.0" />
    </children>

    <ImageView layoutX="30.0" layoutY="390.0" fitHeight="80.0" fitWidth="80.0">
        <image>
            <Image url="@../images/cinema_logo.png" />
        </image>
    </ImageView>
    
</Pane>