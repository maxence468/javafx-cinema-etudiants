<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.QuadCurve?>
<?import javafx.scene.text.Font?>


<Pane maxHeight="-Infinity"
      maxWidth="-Infinity"
      minHeight="-Infinity"
      minWidth="-Infinity"
      prefHeight="478.0"
      prefWidth="804.0"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cinema.controllers.ListeCinemaController">
    <children>
        <VBox layoutX="-1.0" prefHeight="48.0" prefWidth="804.0">
            <children>
                <MenuBar layoutY="1.0" prefHeight="26.0" prefWidth="711.0">
                    <menus>
                        <Menu fx:id="gestionFranchise" mnemonicParsing="false" text="Gestion franchises">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16">
                                    <image>
                                        <Image url="@../images/franchise_64x64.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <items>
                                <MenuItem fx:id="bListeFranchise" mnemonicParsing="false" onAction="#bListFranchiseClick" text="Liste franchises" />
                                <MenuItem fx:id="bAjouterFranchise" mnemonicParsing="false" onAction="#bAjouterFranchiseClick" text="Ajouter une franchise" />
                            </items>
                        </Menu>
                        <Menu fx:id="gestionCinema" mnemonicParsing="false" text="Gestion cinéma">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16">
                                    <image>
                                        <Image url="@../images/cinema_32x32.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <items>
                                <MenuItem fx:id="bListeCinema" mnemonicParsing="false" onAction="#bListeCinemaClick" text="Liste des cinémas" />
                                <MenuItem fx:id="bAjouterCinema" mnemonicParsing="false" onAction="#bAjouterCinemaClick" text="Ajouter un cinéma" />
                            </items>
                        </Menu>
                        <Menu fx:id="gestionSalle" mnemonicParsing="false" text="Gestion salles">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16">
                                    <image>
                                        <Image url="@../images/salle_32x32.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <items>
                                <MenuItem fx:id="bListeSalle" mnemonicParsing="false" onAction="#bListeSalleClick" text="Liste cours" />
                                <MenuItem fx:id="bAjouterSalle" mnemonicParsing="false" onAction="#bAjouterSalleClick" text="Ajouter un cours" />
                            </items>
                        </Menu>
                        <Menu fx:id="bAutres" mnemonicParsing="false" text="Autres">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16">
                                    <image>
                                        <Image url="@../images/info.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <items>
                                <MenuItem fx:id="bAccueil" mnemonicParsing="false" onAction="#bAccueilClick" text="Accueil" />
                                <MenuItem fx:id="bQuitter" mnemonicParsing="false" onAction="#bQuitterClick" text="Quitter" />
                            </items>
                        </Menu>
                    </menus>
                </MenuBar>
            </children>
        </VBox>

      
        <TableView fx:id="tvCinema" layoutY="50.0" prefHeight="292.0" prefWidth="804.0">
            <columns>
                <TableColumn fx:id="tcDenomination" prefWidth="200.0" text="Dénomination" />
                <TableColumn fx:id="tcFranchise" prefWidth="150.0" text="Franchise" />
                <TableColumn fx:id="tcVp" prefWidth="100.0" text="Voir plus" />
                <TableColumn fx:id="tcModif" prefWidth="110.0" text="Modifier" />
                <TableColumn fx:id="tcSupp" prefWidth="110.0" text="Supprimer" />
            </columns>
        </TableView>

      
        <!-- HBox harmonisé pour le bouton de retour -->
        <HBox alignment="CENTER"
              layoutY="355.0"
              prefHeight="115.0"
              prefWidth="804.0"
              spacing="20.0">
            <children>
                <Button fx:id="bRetour"
                        mnemonicParsing="false"
                        onAction="#bRetourClick"
                        prefHeight="39.0"
                        prefWidth="200.0"
                        text="RETOUR"
                        textFill="#024010">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>
            </children>
        </HBox>

      
        <!-- Bande verte en bas pour harmonisation -->
        <Pane layoutX="0.0" layoutY="439.0" prefHeight="39.0" prefWidth="804.0" />
        <QuadCurve controlX="67.66667938232422"
                   controlY="-217.33334350585938"
                   endX="318.33331298828125"
                   endY="-15.000030517578125"
                   fill="#3A3AB6"
                   layoutX="-60.0"
                   layoutY="493.0"
                   startX="-152.3333282470703"
                   startY="-15.000030517578125"
                   stroke="BLACK"
                   strokeType="INSIDE"
                   strokeWidth="0.0" />
        <QuadCurve controlX="190.6666259765625"
                   controlY="-222.33334350585938"
                   endX="45.00006103515625"
                   endY="-15.0"
                   fill="#3A3AB6"
                   layoutX="759.0"
                   layoutY="493.0"
                   startX="-220.66668701171875"
                   startY="-15.0"
                   stroke="BLACK"
                   strokeType="INSIDE"
                   strokeWidth="0.0" />
    </children>
</Pane>
